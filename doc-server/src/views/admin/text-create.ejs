<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Add Text Content - Guru Maa Admin</title>
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Quill Editor CSS -->
  <link href="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.snow.css" rel="stylesheet">
  
  <style>
    :root {
      --bg-color: #f8fafc;
      --card-bg: #ffffff;
      --primary: #6366f1;
      --primary-soft: #eef2ff;
      --text-dark: #1e293b;
      --text-light: #64748b;
      --danger: #ef4444;
      --success: #10b981;
      --radius: 16px;
      --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg-color);
      color: var(--text-dark);
      font-family: 'Plus Jakarta Sans', sans-serif;
      line-height: 1.5;
    }

    .admin-layout { display: flex; min-height: 100vh; }
    .main-content { flex: 1; margin-left: 280px; padding: 40px; }

    .page-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 30px;
    }

    .header-info h1 { font-size: 28px; font-weight: 700; }
    .header-info p { color: var(--text-light); margin-top: 4px; }

    .btn {
      padding: 12px 24px; border-radius: 12px; font-weight: 600;
      border: none; cursor: pointer; text-decoration: none; display: inline-block;
    }
    .btn-primary { background: var(--primary); color: white; }
    .btn-secondary { background: var(--primary-soft); color: var(--primary); }
    .btn-outline { border: 2px solid var(--primary); color: var(--primary); background: transparent; }

    .form-card {
      background: white; border-radius: var(--radius); padding: 32px;
      box-shadow: var(--shadow); max-width: 800px;
    }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px; }
    .form-group { margin-bottom: 20px; }
    
    .form-group label {
      display: block; font-weight: 600; margin-bottom: 8px;
    }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%; padding: 12px; border: 2px solid #e2e8f0;
      border-radius: 10px; font-size: 14px; font-family: inherit;
      transition: border-color 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none; border-color: var(--primary);
    }

    .form-group textarea { min-height: 200px; resize: vertical; }

    .checkbox-group {
      display: flex; gap: 20px; align-items: center;
    }
    .checkbox-group input { width: auto; margin-right: 8px; }

    .form-actions {
      display: flex; gap: 15px; justify-content: flex-end;
      margin-top: 30px; padding-top: 20px; border-top: 1px solid #e2e8f0;
    }

    .tip {
      background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 8px;
      padding: 12px 16px; font-size: 13px; color: #166534; margin-bottom: 20px;
    }

    /* Quill Editor Customization */
    .ql-container { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 14px; }
    .ql-toolbar { border-radius: 10px 10px 0 0; }
    .ql-container { border-radius: 0 0 10px 10px; min-height: 250px; }
    .ql-editor { min-height: 250px; }
    .ql-editor img { max-width: 100%; height: auto; border-radius: 8px; }
    .ql-editor video { max-width: 100%; border-radius: 8px; }

    @media (max-width: 1024px) {
      .main-content { margin-left: 0; padding-top: 80px; }
    }
    @media (max-width: 640px) {
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <div class="admin-layout">
    <%- include('./layouts/sidebar', { currentPage: 'docs' }) %>

    <main class="main-content">
      <header class="page-header">
        <div class="header-info">
          <h1>Add Text Content</h1>
          <p>Create new text-based reading content for your app</p>
        </div>
        <a href="/admin/docs" class="btn btn-secondary">← Back to Documents</a>
      </header>

      <div class="form-card">
        <div class="tip">
          💡 <strong>Tip:</strong> Use this to add chapters, stories, mantras, or any text-based content. 
          You can format your content with paragraphs and it will be displayed beautifully in the app.
        </div>

        <form method="post" action="/admin/docs/create/text">
          <div class="form-row">
            <div class="form-group">
              <label>Title *</label>
              <input type="text" name="title" required placeholder="e.g., Chapter 1: The Beginning">
            </div>
            <div class="form-group">
              <label>Subtitle</label>
              <input type="text" name="subtitle" placeholder="e.g., Arjuna's Dilemma">
            </div>
          </div>

          <div class="form-group">
            <label>Description</label>
            <input type="text" name="description" placeholder="Brief description for the library card">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Category</label>
              <select name="category">
                <option value="">-- No Category --</option>
                <% if (categories && categories.length > 0) { %>
                  <% categories.forEach(function(cat) { %>
                    <option value="<%= cat._id %>"><%= cat.icon %> <%= cat.name %></option>
                  <% }) %>
                <% } %>
              </select>
            </div>
            <div class="form-group">
              <label>Author</label>
              <input type="text" name="author" placeholder="e.g., Vyasa">
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label>Total Pages / Chapters</label>
              <input type="number" name="totalPages" value="1" min="1">
            </div>
            <div class="form-group" style="display: flex; flex-direction: column; justify-content: flex-end;">
              <div class="checkbox-group">
                <input type="checkbox" name="isPublished" id="isPublished" checked>
                <label for="isPublished">Publish immediately</label>
              </div>
              <div class="checkbox-group" style="margin-top: 10px;">
                <input type="checkbox" name="isFeatured" id="isFeatured">
                <label for="isFeatured">Mark as featured</label>
              </div>
            </div>
          </div>

          <div class="form-group">
            <label>Content *</label>
            <div id="editor-container" style="background: white;"></div>
            <input type="hidden" name="textContent" id="textContent">
          </div>

          <div class="form-actions">
            <a href="/admin/docs" class="btn btn-outline">Cancel</a>
            <button type="submit" class="btn btn-primary">Create Content</button>
          </div>
        </form>
      </div>
    </main>
  </div>

  <%- include('./layouts/flash-toast') %>
  
  <!-- Quill Editor JS -->
  <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
  <script>
    // Initialize Quill editor
    var quill = new Quill('#editor-container', {
      theme: 'snow',
      placeholder: 'Enter your content here...\n\nYou can format text, add images, create lists, and more.',
      modules: {
        toolbar: [
          [{ 'header': [1, 2, 3, false] }],
          ['bold', 'italic', 'underline', 'strike'],
          [{ 'color': [] }, { 'background': [] }],
          [{ 'list': 'ordered'}, { 'list': 'bullet' }],
          [{ 'indent': '-1'}, { 'indent': '+1' }],
          ['link', 'image', 'video'],
          ['clean']
        ]
      }
    });
    
    // Handle form submission
    document.querySelector('form').addEventListener('submit', function() {
      // Copy Quill content to hidden input
      document.getElementById('textContent').value = quill.root.innerHTML;
    });
  </script>
</body>
</html>
