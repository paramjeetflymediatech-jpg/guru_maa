<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Document Manager - Guru Maa Admin</title>
  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    :root {
      --bg-color: #f8fafc;
      --card-bg: #ffffff;
      --primary: #6366f1;
      --primary-soft: #eef2ff;
      --text-dark: #1e293b;
      --text-light: #64748b;
      --danger: #ef4444;
      --success: #10b981;
      --radius: 16px;
      --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background: var(--bg-color);
      color: var(--text-dark);
      font-family: 'Plus Jakarta Sans', sans-serif;
      line-height: 1.5;
    }

    .admin-layout {
      display: flex;
      min-height: 100vh;
    }

    /* Main Content Area */
    .main-content {
      flex: 1;
      margin-left: 280px; /* Aligned with our modern sidebar */
      padding: 40px;
      transition: all 0.3s ease;
    }

    /* Page Header */
    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 40px;
      gap: 20px;
    }

    .header-info h1 {
      font-size: 32px;
      font-weight: 700;
      letter-spacing: -1px;
      color: var(--text-dark);
    }

    .header-info p {
      color: var(--text-light);
      margin-top: 4px;
    }

    /* Modern Upload Section */
    .upload-zone {
      background: var(--card-bg);
      border: 2px dashed #e2e8f0;
      border-radius: var(--radius);
      padding: 40px;
      text-align: center;
      transition: all 0.3s ease;
      margin-bottom: 40px;
      position: relative;
      display: none; /* Hidden by default */
    }

    .upload-zone.active {
      display: block;
      animation: slideDown 0.3s ease-out;
    }

    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .upload-zone:hover {
      border-color: var(--primary);
      background: var(--primary-soft);
    }

    .upload-form {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 15px;
    }

    .file-input-wrapper {
      position: relative;
      cursor: pointer;
    }

    .upload-form input[type="file"] {
      position: absolute;
      left: 0; top: 0; opacity: 0;
      width: 100%; height: 100%;
      cursor: pointer;
    }

    .btn-upload-trigger {
      background: var(--primary);
      color: white;
      padding: 12px 30px;
      border-radius: 12px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.3);
    }

    /* Document Grid (The Unique Part) */
    .doc-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 24px;
    }

    .doc-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 24px;
      box-shadow: var(--shadow);
      border: 1px solid #f1f5f9;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .doc-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
    }

    .doc-icon {
      width: 48px;
      height: 48px;
      background: var(--primary-soft);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      margin-bottom: 16px;
    }

    .doc-title {
      font-weight: 700;
      font-size: 16px;
      margin-bottom: 4px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .doc-meta {
      font-size: 13px;
      color: var(--text-light);
      margin-bottom: 20px;
    }

    .doc-meta span {
      display: inline-block;
      margin-right: 10px;
    }

    .doc-actions {
      display: flex;
      gap: 10px;
      border-top: 1px solid #f1f5f9;
      padding-top: 16px;
    }

    .btn-action {
      flex: 1;
      padding: 10px;
      border-radius: 8px;
      text-align: center;
      text-decoration: none;
      font-size: 13px;
      font-weight: 600;
      transition: 0.2s;
    }

    .btn-view { background: var(--primary-soft); color: var(--primary); }
    .btn-view:hover { background: var(--primary); color: white; }

    .btn-delete-icon { background: #fee2e2; color: var(--danger); border: none; cursor: pointer; }
    .btn-delete-icon:hover { background: var(--danger); color: white; }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 20px;
      border-radius: 10px;
      font-weight: 600;
      font-size: 14px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .btn-primary {
      background: var(--primary);
      color: white;
      box-shadow: 0 4px 6px -1px rgba(99, 102, 241, 0.2);
    }

    .btn-primary:hover {
      background: #4f46e5;
      transform: translateY(-1px);
      box-shadow: 0 6px 8px -1px rgba(99, 102, 241, 0.3);
    }

    .btn-secondary {
      background: white;
      color: var(--text-dark);
      border: 1px solid #e2e8f0;
    }

    .btn-secondary:hover {
      background: #f8fafc;
      border-color: #cbd5e1;
    }

    /* Search Section */
    .search-section {
      background: var(--card-bg);
      border-radius: var(--radius);
      padding: 24px;
      margin-bottom: 30px;
      box-shadow: var(--shadow);
      border: 1px solid #f1f5f9;
    }

    .search-form {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .search-input-wrapper {
      flex: 1;
      position: relative;
    }

    .search-icon {
      position: absolute;
      left: 16px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--text-light);
      font-size: 18px;
    }

    .search-input {
      width: 100%;
      padding: 14px 16px 14px 44px;
      border: 2px solid #e2e8f0;
      border-radius: 12px;
      font-size: 15px;
      color: #1e293b;
      transition: all 0.2s ease;
      background: #f8fafc;
    }

    .search-input:focus {
      outline: none;
      border-color: var(--primary);
      background: white;
      box-shadow: 0 0 0 4px var(--primary-soft);
    }

    /* Empty State */
    .empty-container {
      grid-column: 1 / -1;
      text-align: center;
      padding: 60px;
      background: white;
      border-radius: var(--radius);
    }

    /* Responsive Adjustments */
    @media (max-width: 1024px) {
      .main-content { margin-left: 0; padding-top: 80px; }
      .page-header { flex-direction: column; align-items: flex-start; }
    }

    @media (max-width: 480px) {
      .doc-grid { grid-template-columns: 1fr; }
      .header-info h1 { font-size: 24px; }
    }
  </style>
</head>

<body>
  <div class="admin-layout">
    <%- include('./layouts/sidebar', { currentPage: 'docs' }) %>

    <main class="main-content">
      <header class="page-header">
        <div class="header-info">
          <h1>Asset Library</h1>
          <p>Organize and manage your digital documents</p>
        </div>
        <div style="display: flex; gap: 10px;">
          <a href="/admin/docs/create/text" class="btn btn-secondary" style="background: #f0fdf4; color: #16a34a;">+ Add Text Content</a>
          <button type="button" class="btn btn-primary" id="btn-show-upload">Upload PDF</button>
        </div>
      </header>

      <!-- Search Section -->
      <section class="search-section">
        <div class="search-form">
          <div class="search-input-wrapper">
            <span class="search-icon">🔍</span>
            <input type="text" class="search-input" placeholder="Search documents by title, folder, or type..." 
              value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>">
          </div>
          <button type="button" class="btn btn-secondary" onclick="document.querySelector('.search-input').value=''; document.querySelector('.search-input').dispatchEvent(new Event('input'))">Clear</button>
        </div>
      </section>

      <section class="upload-zone" id="upload-zone">
        <form method="post" action="/admin/docs/upload" enctype="multipart/form-data" class="upload-form">
          <button type="button" class="btn-close-upload" onclick="document.getElementById('upload-zone').classList.remove('active')" 
            style="position: absolute; right: 20px; top: 20px; background: none; border: none; font-size: 20px; cursor: pointer; color: var(--text-light);">✕</button>
          
          <div class="doc-icon" style="margin: 0 auto 15px auto;">📁</div>
          <h3>Drop your files here</h3>
          <p style="color: var(--text-light); font-size: 14px; margin-bottom: 20px;">Support for PDF, DOCX, and Images</p>
          
          <div class="file-input-wrapper">
            <button type="button" class="btn-upload-trigger">Select File</button>
            <input type="file" name="file" required onchange="this.form.submit()" />
          </div>
          <button type="button" class="btn" style="margin-top: 10px; font-size: 13px;" onclick="document.getElementById('upload-zone').classList.remove('active')">Cancel</button>
        </form>
      </section>

      <section class="doc-grid">
        <% if (docs && docs.length > 0) { %>
          <% docs.forEach(function(doc) { %>
            <article class="doc-card">
              <div>
                <div class="doc-icon">
                  <% if(doc.type && doc.type.includes('pdf')) { %> 📕 
                  <% } else if(doc.type && doc.type.includes('image')) { %> 🖼️
                  <% } else { %> 📄 <% } %>
                </div>
                <h3 class="doc-title"><%= doc.title %></h3>
                <div class="doc-meta">
                  <span>📂 <%= doc.folder || 'Main' %></span>
                  <span>•</span>
                  <span>📅 <%= doc.type || 'File' %></span>
                </div>
              </div>

              <div class="doc-actions">
                <a href="/admin/docs/edit/<%= doc._id %>" class="btn-action btn-view">✏️ Edit</a>
                <a href="<%= doc.url %>" target="_blank" class="btn-action btn-view">View Asset</a>
                
                <form method="post" action="/admin/docs/delete" style="flex: 0 0 45px;">
                  <input type="hidden" name="id" value="<%= doc._id %>" />
                  <button type="submit" class="btn-action btn-delete-icon" onclick="return confirm('Delete permanently?')">
                    🗑️
                  </button>
                </form>
              </div>
            </article>
          <% }) %>
        <% } else { %>
          <div class="empty-container">
            <div style="font-size: 50px; margin-bottom: 20px;">☁️</div>
            <h3>Your library is empty</h3>
            <p style="color: var(--text-light);">Start by uploading a document above.</p>
          </div>
        <% } %>
        
        <div class="no-results-container" style="display: none; grid-column: 1 / -1; text-align: center; padding: 60px; background: white; border-radius: var(--radius);">
          <div style="font-size: 50px; margin-bottom: 20px;">🔍</div>
          <h3>No results found</h3>
          <p style="color: var(--text-light);">We couldn't find any documents matching your search.</p>
        </div>
      </section>

      <div class="pagination-wrapper" style="margin-top: 40px;">
        <%- include('./layouts/pagination') %>
      </div>
    </main>
  </div>

  <%- include('./layouts/flash-toast') %>

  <script>
    // Live Client-Side Search
    const searchInput = document.querySelector('.search-input');
    const docCards = document.querySelectorAll('.doc-card');
    const noResultsContainer = document.querySelector('.no-results-container');
    const paginationWrapper = document.querySelector('.pagination-wrapper');

    if (searchInput) {
      const originalCount = document.getElementById('pagination-item-count')?.innerText;
      const originalCurrentPage = document.getElementById('pagination-current-page')?.innerText;
      const originalTotalPages = document.getElementById('pagination-total-pages')?.innerText;

      searchInput.addEventListener('input', function(e) {
        const query = e.target.value.toLowerCase().trim();
        let visibleCount = 0;
        
        docCards.forEach(card => {
          const textContent = card.innerText.toLowerCase();
          
          if (query === '' || textContent.includes(query)) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Update pagination info
        const countSpan = document.getElementById('pagination-item-count');
        const currPageSpan = document.getElementById('pagination-current-page');
        const totalPagesSpan = document.getElementById('pagination-total-pages');
        const paginationLinks = document.getElementById('pagination-links');

        if (countSpan) countSpan.innerText = query === '' ? originalCount : visibleCount;
        
        if (query !== '') {
          if (currPageSpan) currPageSpan.innerText = '1';
          if (totalPagesSpan) totalPagesSpan.innerText = '1';
          if (paginationLinks) paginationLinks.style.display = 'none';
        } else {
          if (currPageSpan) currPageSpan.innerText = originalCurrentPage;
          if (totalPagesSpan) totalPagesSpan.innerText = originalTotalPages;
          if (paginationLinks) paginationLinks.style.display = 'flex';
        }

        // Toggle No Results State
        if (noResultsContainer && docCards.length > 0) {
          if (visibleCount === 0) {
            noResultsContainer.style.display = 'block';
          } else {
            noResultsContainer.style.display = 'none';
          }
        }
      });
    }

    // Toggle Upload Zone
    const btnShowUpload = document.getElementById('btn-show-upload');
    const uploadZone = document.getElementById('upload-zone');
    if (btnShowUpload && uploadZone) {
      btnShowUpload.addEventListener('click', () => {
        uploadZone.classList.toggle('active');
        if (uploadZone.classList.contains('active')) {
          uploadZone.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      });
    }

    // Smooth file name feedback (Optional)
    const fileInput = document.querySelector('input[type="file"]');
    fileInput.addEventListener('change', function(e) {
      if(this.files.length > 0) {
        document.querySelector('.upload-zone h3').innerText = "Uploading: " + this.files[0].name;
      }
    });
  </script>
</body>
</html>